# =============================================================================
# Unified Matter Intelligence Center — Environment Template
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# --- Application ---
APP_NAME=Unified Matter Intelligence Center
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-secret-at-least-64-chars
CORS_ORIGINS=http://localhost:3000

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=umic
POSTGRES_PASSWORD=umic_dev_password_change_me
POSTGRES_DB=umic
DATABASE_URL=postgresql+psycopg://umic:umic_dev_password_change_me@postgres:5432/umic

# Local (non-Docker) override example:
# DATABASE_URL=postgresql+psycopg://umic:umic_dev_password_change_me@localhost:5432/umic

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT / Auth ---
JWT_SECRET_KEY=change-me-jwt-secret-at-least-64-characters-long-random
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_HASH_SCHEME=bcrypt

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_DEFAULT=100/minute

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Unified Matter Intelligence Center

# --- Google OAuth + API (never commit real values) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_API_KEY=
GOOGLE_GMAIL_API_KEY=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/callback

# --- Dropbox OAuth ---
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:8000/api/v1/integrations/dropbox/callback

# --- Seed / Bootstrap Admin ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMeAdmin123!
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Owner
